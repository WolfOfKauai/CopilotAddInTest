<?xml version="1.0" encoding="utf-8" ?>
<ArcGIS defaultAssembly="LookupFireDamageOrig.dll"
        defaultNamespace="LookupFireDamageOrig"
        xmlns="http://schemas.esri.com/DADF/Registry"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://schemas.esri.com/DADF/Registry https://github.com/Esri/arcgis-pro-sdk/blob/master/References/ArcGIS.Desktop.Framework.xsd">

  <AddInInfo id="{155ecc81-f1bf-403d-b56d-755f1437100a}" version="1.0" desktopVersion="3.7.395" product="ArcGISPro">
    <Name>LookupFireDamageOrig</Name>   
    <Description>LookupFireDamageOrig description</Description>
    <Image>Images\AddinDesktop32.png</Image>
    <Author>wlfka</Author>
    <Company>Acme</Company>
    <Date>1/27/2026 11:16:01 AM</Date>
    <Subject>Framework</Subject>
    <!-- Note subject can be one or more of these topics:
                    Content, Framework, Editing, Geodatabase, Geometry, Geoprocessing, Layouts, Map Authoring, Map Exploration -->
  </AddInInfo>

  <modules>
    <insertModule id="LookupFireDamageOrig_Module" className="Module1" autoLoad="false" caption="Module1">
      <!-- uncomment to have the control hosted on a separate tab-->
      <tabs>
        <tab id="FireDamage_Tab" caption="Fire Damage">
          <group refID="DamageLookup_Group" />
        </tab>
      </tabs>
              
      <groups>
        <group id="DamageLookup_Group" caption="Damage Lookup" appearsOnAddInTab="false">
          <button refID="StructureDamageLookup_Button" size="large" />
        </group>
      </groups>
      
      <controls>
        <button id="StructureDamageLookup_Button"
                caption="Structure Damage Lookup"
                className="StructureDamageLookupButton"
                loadOnClick="true"
                smallImage="FireSimulation16"
                largeImage="FireSimulation32"
                keytip="SDL">
          <tooltip heading="Lookup Structure Damage">Lookup structure damage by parcel.<disabledText /></tooltip>
        </button>
      </controls>
      <dockPanes>
        <dockPane id="ParcelDockpane"
                  caption="Parcel Lookup"
                  className="ParcelDockpaneViewModel"
                  dock="group"
                  dockWith="esri_core_projectDockPane">
          <content className="ParcelDockpaneView" />
        </dockPane>
      </dockPanes>    
  </insertModule>
  </modules>
</ArcGIS>